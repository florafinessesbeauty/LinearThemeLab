{
  "compilerOptions": {  
    "types": ["node"],
    "target": "ES2020",
    "lib": ["DOM", "ES2020"],
    "module": "ESNext",

    "moduleResolution": "bundler",

    "allowJs": false,
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",

    "baseUrl": ".",
    "paths": {
      "@/*": ["*"],
      "@linearthemelab/shared": ["packages/shared/src"],
      "@linearthemelab/shared/*": ["packages/shared/src/*"]
    },

    "noEmit": true,
    "incremental": true,

    

    "plugins": [
      {
        "name": "next"
      }
    ]
  },

  "include": [
  "app",
  "server/src",
  "packages/shared/src",
  "next-env.d.ts",
  ".next/types/**/*.ts"
],

  "exclude": [
    "node_modules",
    ".next",
    "server/dist"
  ]
}
