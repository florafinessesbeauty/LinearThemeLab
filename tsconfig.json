{
  "compilerOptions": {
    "types": [
      "node"
    ],
    "target": "ES2020",
    "lib": [
      "DOM",
      "ES2020"
    ],
    "module": "node16",
    "moduleResolution": "node16",
    "allowJs": false,
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "paths": {
      "@linearthemelab/shared": [
        "./packages/shared/src"
      ],
      "@linearthemelab/shared/*": [
        "./packages/shared/src/*"
      ],
      "@server/*": [
        "./server/src/*"
      ]
    },
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "noEmit": true
  },
  "references": [
    {
      "path": "packages/shared"
    }
  ],
  "include": [
    "app",
    "server/src",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "server/dist",
    "packages/*/dist"
  ]
}
