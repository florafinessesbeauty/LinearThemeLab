{
  "compilerOptions": {
    "types": ["node"],
    "target": "ES2020",
    "lib": ["DOM", "ES2020"],
    "module": "ESNext",
    "moduleResolution": "node",
    "allowJs": false,
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",

    "baseUrl": ".",
    "paths": {
      "@/*": ["*"],
      "@linearthemelab/shared": ["packages/shared/src"],
      "@linearthemelab/shared/*": ["packages/shared/src/*"]
    },

    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "references": [
    { "path": "packages/shared" }
  ],
  "include": [
    "app",
    "server/src",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "server/dist",
    "packages/*/dist"
  ]
}
