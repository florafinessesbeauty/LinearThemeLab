{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "ES2020"],
    "module": "ESNext",

    // Modern, TS6+ safe module resolution
    "moduleResolution": "bundler",

    // Required for Next.js + monorepo
    "allowJs": false,
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",

    // Monorepo path aliases
    "baseUrl": ".",
    "paths": {
      "@linearthemelab/shared": ["packages/shared/src"],
      "@linearthemelab/shared/*": ["packages/shared/src/*"]
    },

    // Next.js required
    "noEmit": true,
    "incremental": true,

    // Silence TS6 deprecation warnings
    "ignoreDeprecations": "6.0",

    "plugins": [
      {
        "name": "next"
      }
    ]
  },

  "include": [
    "app",
    "server/src",
    "packages/shared/src",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],

  "exclude": [
    "node_modules",
    ".next",
    "server/dist"
  ]
}
