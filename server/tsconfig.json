{
  "compilerOptions": {
    "target": "ES2020",

    "module": "node16",
    "moduleResolution": "node16",

    "rootDir": "src",
    "outDir": "dist",

    "paths": {
      "*": ["./src/*"]
    },

    "lib": ["ES2020"],
    "esModuleInterop": true,
    "strict": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
