{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",

    "module": "node16",
    "moduleResolution": "node16",

    "rootDir": "src",
    "outDir": "dist",

    "paths": {
      "@linearthemelab/shared": ["../packages/shared/dist"],
      "@linearthemelab/shared/*": ["../packages/shared/dist/*"]
    },

    "composite": true,
    "declaration": true,
    "declarationMap": true
  },
  "references": [
    { "path": "../packages/shared" }
  ],
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
