{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",

    "module": "node16",
    "moduleResolution": "node16",

    "rootDir": "src",
    "outDir": "dist",

    "baseUrl": "..",
    "paths": {
      "@linearthemelab/shared": ["packages/shared/dist"],
      "@linearthemelab/shared/*": ["packages/shared/dist/*"]
    },

    "lib": ["ES2020"],
    "esModuleInterop": true,
    "strict": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "composite": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
